<idea-plugin>
  <id>io.gitconflictradar</id>
  <name>GitConflictRadar</name>
  <vendor email="hello@gitconflictradar.io">GitConflictRadar</vendor>
  <description><![CDATA[
    Detects potential Git merge conflicts before they interrupt your workflow.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>Git4Idea</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="io.gitconflictradar.settings.GitConflictRadarSettings"/>
    <projectService serviceImplementation="io.gitconflictradar.core.GitConflictRadarService"/>
    <projectService serviceImplementation="io.gitconflictradar.ui.GitConflictRadarInlayManager"/>
    <projectViewNodeDecorator implementation="io.gitconflictradar.ui.GitConflictRadarProjectViewDecorator"/>
    <codeInsight.lineMarkerProvider language="JAVA" implementationClass="io.gitconflictradar.ui.GitConflictRadarLineMarkerProvider"/>
    <codeInsight.lineMarkerProvider language="kotlin" implementationClass="io.gitconflictradar.ui.GitConflictRadarLineMarkerProvider"/>
    <applicationConfigurable
        id="io.gitconflictradar.settings"
        displayName="GitConflictRadar"
        instance="io.gitconflictradar.settings.GitConflictRadarSettingsConfigurable"/>
    <toolWindow id="GitConflictRadar"
                anchor="right"
                factoryClass="io.gitconflictradar.ui.GitConflictRadarToolWindowFactory"/>
    <diff.DiffExtension implementation="io.gitconflictradar.ui.GitConflictRadarDiffExtension"/>
    <notificationGroup id="GitConflictRadar Notifications" displayType="BALLOON" isLogByDefault="true"/>
  </extensions>

  <actions>
    <action id="io.gitconflictradar.RefreshRepositories"
            class="io.gitconflictradar.actions.RefreshRepositoriesAction"
            text="Refresh repositories"
            description="Fetch and analyse Git repositories for potential merge conflicts">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
